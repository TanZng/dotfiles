{
    "$schema": "https://charm.land/crush.json",
    "options": {
        "disable_metrics": true,
        "attribution": {
            "co_authored_by": false,
            "generated_with": false
        }
    },
    "lsp": {
        "go": {
            "command": "gopls",
            "env": {
                "GOTOOLCHAIN": "go1.25.1"
            }
        }
    },
    "permissions": {
        "allowed_tools": [
            "view",
            "ls",
            "grep",
            "edit"
        ]
    },
    "providers": {
        "ollama": {
            "name": "Ollama",
            "base_url": "http://localhost:11434/v1/",
            "type": "openai",
            "models": [
                {
                    "name": "GPT OSS",
                    "id": "gpt-oss:20b",
                    "context_window": 256000,
                    "default_max_tokens": 20000
                },
                {
                    "name": "Mistral",
                    "id": "mistral:latest",
                    "context_window": 256000,
                    "default_max_tokens": 20000
                },
                {
                    "name": "Orca Mini",
                    "id": "orca-mini:3b",
                    "context_window": 256000,
                    "default_max_tokens": 20000
                },
                {
                    "name": "Qwen 3 Coder",
                    "id": "qwen3-coder:30b",
                    "context_window": 256000,
                    "default_max_tokens": 20000
                }
            ]
        }
    }
}
